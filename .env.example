TRANSPORT=http
PORT=3000
MCP_HTTP_PATH=/mcp

# Optional bearer auth for remote MCP clients.
MCP_AUTH_TOKEN=change-me

# Optional default residential proxy.
# Use either PROXY_URL or PROXY_SERVER (+ optional credentials).
# PROXY_URL=http://user:pass@host:port
PROXY_SERVER=http://host:port
PROXY_USERNAME=
PROXY_PASSWORD=
